.DS_Store
**/.DS_Store

# VS Code (we only export User settings/snippets)
vscode/**/globalStorage/
vscode/**/workspaceStorage/
vscode/**/History/

# Codex (avoid secrets/state if accidentally copied later)
codex/auth.json
codex/history.jsonl
codex/log/
codex/sessions/
codex/shell_snapshots/
codex/sqlite/
codex/tmp/
codex/models_cache.json
codex/.codex-global-state.json

# Raycast (avoid large local DBs if accidentally copied later)
raycast/*.sqlite
raycast/*.sqlite-*
raycast/NodeJS/
raycast/RaycastWrapped/
raycast/Updates/
raycast/extensions/

