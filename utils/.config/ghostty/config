# ==============================================
# CYBERPUNK DEV PRESET
# ==============================================
# Combination: Tokyo Night + Fira Code
# Perfect for: Modern web development, React/TypeScript, futuristic coding
# Vibe: Neon-lit coding sessions, cyberpunk aesthetic

# Tokyo Night Theme - CORRECTED
theme = "Catppuccin Mocha"

# JetBrains Mono Nerd Font - optimizado para ASCII art, Unicode y ligatures
font-family = Berkeley Mono
font-size = 16
font-thicken = true
font-feature = +calt,+liga
cursor-click-to-move = true
link-previews = osc8
shell-integration = detect
link-url = true
keybind = cmd+p=toggle_command_palette

# Optimizaciones para renderizado de caracteres Unicode y ASCII art
adjust-box-thickness = 1
adjust-cell-width = 0
grapheme-width-method = unicode

# Cyberpunk window styling - CORRECTED OPTIONS
window-padding-x = 16
window-padding-y = 12
window-decoration = true

# Futuristic cursor
cursor-style = bar
cursor-opacity = 0.9

# Enhanced visual effects
minimum-contrast = 1.2

# Tokyo Night selection - CORRECTED
selection-background = #2196f3

# Transparency and blur (Warp-like glassmorphism)
background-opacity = 0.92
background-blur = 20

macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden

# Custom shaders
custom-shader = shaders/cursor_warp.glsl
custom-shader = shaders/bloom.glsl

shell-integration = zsh

focus-follows-mouse = true

shell-integration = detect
shell-integration-features = cursor,sudo,title

macos-titlebar-style = transparent

# AI NOTES FOR CYBERPUNK DEV:
# - Maximum transparency (0.85) for futuristic glass effect
# - High blur (25) creates neon glow atmosphere
# - Fira Code ligatures perfect for modern JS/TS syntax
# - Enhanced padding showcases the beautiful ligatures
# - Low unfocused opacity (0.5) creates dramatic focus effect

# ==============================================
# Productivity Keybindings
# ==============================================

# Text operations
keybind = shift+enter=text:\x1b\r
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

# Font size control
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size

# Navigation
keybind = cmd+k=clear_screen
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+w=close_window

# Split management
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+shift+enter=toggle_split_zoom

# Tab navigation
keybind = super+alt+left=previous_tab
keybind = super+alt+right=next_tab
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=goto_tab:9
