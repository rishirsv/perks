  "documents": {
    "operations": [
      "product_catalog",
      "sales_transactions",
      "inventory_ledger",
      "supplier_master",
      "purchase_orders",
      "store_master",
      "daily_sales_summary"
    ],
    "financials": [
      "trial_balance",
      "income_statement",
      "balance_sheet",
      "cash_flow",
      "ar_aging",
      "ap_aging",
      "inventory_valuation",
      "store_level_pl"
    ]
  },

  "consistency_rules": [
    {
      "id": "sales_transaction_tie",
      "description": "Sum of sales transactions equals P&L retail sales",
      "check": "sum(sales_transactions.amount) == income_statement.retail_sales"
    },
    {
      "id": "inventory_flow",
      "description": "COGS = Beginning inventory + Purchases - Ending inventory",
      "check": "cogs == beginning_inventory + purchases - ending_inventory"
    },
    {
      "id": "inventory_ledger_tie",
      "description": "Inventory ledger totals tie to balance sheet inventory",
      "check": "sum(inventory_ledger.value) == balance_sheet.inventory"
    },
    {
      "id": "store_pl_consolidation",
      "description": "Sum of store-level P&Ls equals consolidated P&L",
      "check": "sum(store_pl.net_income) == income_statement.net_income"
    }
  ],

  "seasonality_patterns": {
    "q1": 0.18,
    "q2": 0.22,
    "q3": 0.22,
    "q4": 0.38,
    "notes": "Heavy Q4 holiday season; Q1 post-holiday slowdown",
    "monthly": {
      "jan": 0.05, "feb": 0.06, "mar": 0.07,
      "apr": 0.07, "may": 0.08, "jun": 0.07,
      "jul": 0.07, "aug": 0.08, "sep": 0.07,
      "oct": 0.09, "nov": 0.13, "dec": 0.16
    }
  },

  "kpis": {
    "gross_margin": {"min": 0.35, "max": 0.55, "typical": 0.42},
    "inventory_turns": {"min": 3, "max": 8, "typical": 5},
    "sales_per_sqft": {"min": 200, "max": 600, "typical": 350},
    "four_wall_margin": {"min": 0.10, "max": 0.25, "typical": 0.15},
    "shrink_rate": {"min": 0.01, "max": 0.03, "typical": 0.015}
  },

  "qoe_adjustments": {
    "common": [
      "Inventory reserve / obsolescence",
      "Gift card breakage timing",
      "Lease accounting adjustments",
      "Shrinkage reserve normalization"
    ],
    "owner_addbacks": [
      "Owner compensation normalization",
      "Related party rent",
      "Personal purchases through store"
    ]
  },

  "departments": [
