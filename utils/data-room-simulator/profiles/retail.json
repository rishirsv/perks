      {"code": "6200", "name": "Marketing & Advertising", "typical_pct": 0.04},
      {"code": "6300", "name": "General & Administrative", "typical_pct": 0.06},
      {"code": "6400", "name": "Utilities", "typical_pct": 0.02}
    ],
