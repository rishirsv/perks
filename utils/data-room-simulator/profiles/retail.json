      {"code": "2100", "name": "Accrued Expenses"},
      {"code": "2200", "name": "Accrued Payroll"},
      {"code": "2300", "name": "Gift Card Liability"},
      {"code": "2400", "name": "Sales Tax Payable"},
      {"code": "2500", "name": "Line of Credit"},
      {"code": "2600", "name": "Lease Liabilities"}
    ],
    "equity": [
      {"code": "3000", "name": "Common Stock"},
      {"code": "3100", "name": "Retained Earnings"},
      {"code": "3200", "name": "Shareholder Distributions"}
