{
  "industry": "saas",
  "display_name": "Software-as-a-Service",
  "revenue_model": "subscription",
  "description": "Recurring subscription revenue with MRR/ARR metrics, customer churn, and deferred revenue",

  "bounds": {
    "small": {
      "revenue_min": 5000000,
      "revenue_max": 20000000,
      "headcount_min": 20,
      "headcount_max": 80,
      "customer_count_min": 50,
      "customer_count_max": 500
    },
    "mid": {
      "revenue_min": 20000000,
      "revenue_max": 100000000,
      "headcount_min": 80,
      "headcount_max": 400,
      "customer_count_min": 200,
      "customer_count_max": 2000
    },
    "large": {
      "revenue_min": 100000000,
      "revenue_max": 500000000,
      "headcount_min": 400,
      "headcount_max": 2000,
      "customer_count_min": 1000,
      "customer_count_max": 10000
    }
  },

  "chart_of_accounts": {
    "revenue": [
      {"code": "4000", "name": "Subscription Revenue", "typical_pct": 0.85},
      {"code": "4100", "name": "Professional Services Revenue", "typical_pct": 0.10},
      {"code": "4200", "name": "Other Revenue", "typical_pct": 0.05}
    ],
    "cogs": [
      {"code": "5000", "name": "Hosting & Infrastructure", "typical_pct": 0.08},
      {"code": "5100", "name": "Customer Support Salaries", "typical_pct": 0.06},
      {"code": "5200", "name": "Third-Party Software", "typical_pct": 0.02}
    ],
    "opex": [
      {"code": "6000", "name": "Sales & Marketing", "typical_pct": 0.25},
      {"code": "6100", "name": "Research & Development", "typical_pct": 0.20},
      {"code": "6200", "name": "General & Administrative", "typical_pct": 0.15}
    ],
    "assets": [
      {"code": "1000", "name": "Cash and Cash Equivalents"},
      {"code": "1100", "name": "Accounts Receivable"},
      {"code": "1200", "name": "Prepaid Expenses"},
      {"code": "1300", "name": "Capitalized Software Costs"},
      {"code": "1400", "name": "Property and Equipment"},
      {"code": "1500", "name": "Accumulated Depreciation"}
    ],
    "liabilities": [
      {"code": "2000", "name": "Accounts Payable"},
      {"code": "2100", "name": "Accrued Expenses"},
      {"code": "2200", "name": "Deferred Revenue - Current"},
      {"code": "2300", "name": "Deferred Revenue - Long-term"},
      {"code": "2400", "name": "Notes Payable"},
      {"code": "2500", "name": "Line of Credit"}
    ],
    "equity": [
      {"code": "3000", "name": "Common Stock"},
      {"code": "3100", "name": "Additional Paid-in Capital"},
      {"code": "3200", "name": "Retained Earnings"}
    ]
  },

  "documents": {
    "operations": [
      "customer_master",
      "subscription_register",
      "invoice_register",
      "mrr_analysis",
      "product_plan_master",
      "churn_analysis"
    ],
    "financials": [
      "trial_balance",
      "income_statement",
      "balance_sheet",
      "cash_flow",
      "ar_aging",
      "ap_aging",
      "deferred_revenue_schedule"
    ]
  },

  "consistency_rules": [
    {
      "id": "mrr_to_arr",
      "description": "MRR × 12 should approximate annual subscription revenue",
      "check": "abs(ending_mrr * 12 - annual_subscription_revenue) / annual_subscription_revenue < 0.15"
    },
    {
      "id": "deferred_revenue_tie",
      "description": "Deferred revenue schedule ending balance ties to balance sheet",
      "check": "deferred_revenue_schedule.ending_balance == balance_sheet.deferred_revenue"
    },
    {
      "id": "customer_revenue_tie",
      "description": "Sum of customer-level revenue equals P&L subscription revenue",
      "check": "sum(customer_revenue) == income_statement.subscription_revenue"
    },
    {
      "id": "subscription_count_tie",
      "description": "Active subscription count ties to customer master",
      "check": "subscription_register.active_count == customer_master.active_customers"
    }
  ],

  "seasonality_patterns": {
    "q1": 0.22,
    "q2": 0.24,
    "q3": 0.25,
    "q4": 0.29,
    "notes": "Slight Q4 uptick from year-end budget flush"
  },

  "kpis": {
    "gross_margin": {"min": 0.70, "max": 0.85, "typical": 0.78},
    "net_revenue_retention": {"min": 0.95, "max": 1.30, "typical": 1.10},
    "gross_churn": {"min": 0.02, "max": 0.15, "typical": 0.08},
    "ltv_cac_ratio": {"min": 2.0, "max": 5.0, "typical": 3.0},
    "magic_number": {"min": 0.5, "max": 1.5, "typical": 0.8}
  },

  "qoe_adjustments": {
    "common": [
      "One-time implementation revenue recognized upfront",
      "Capitalized software costs (R&D vs. development split)",
      "Stock-based compensation add-back",
      "Non-recurring legal/IP costs"
    ],
    "owner_addbacks": [
      "Above-market executive compensation",
      "Related party software licensing fees"
    ]
  },

  "departments": [
    {"name": "Engineering", "typical_pct": 0.35},
    {"name": "Sales", "typical_pct": 0.25},
    {"name": "Customer Success", "typical_pct": 0.15},
    {"name": "Marketing", "typical_pct": 0.10},
    {"name": "G&A", "typical_pct": 0.10},
    {"name": "Product", "typical_pct": 0.05}
  ]
}
