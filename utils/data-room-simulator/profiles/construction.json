{
  "industry": "construction",
  "display_name": "Construction / Contracting",
  "revenue_model": "project_based",
  "description": "Project-based revenue with WIP accounting, percentage of completion, retention, and subcontractor management",

  "bounds": {
    "small": {
      "revenue_min": 5000000,
      "revenue_max": 20000000,
      "headcount_min": 15,
      "headcount_max": 60,
      "project_count_min": 5,
      "project_count_max": 25
    },
    "mid": {
      "revenue_min": 20000000,
      "revenue_max": 100000000,
      "headcount_min": 50,
      "headcount_max": 250,
      "project_count_min": 15,
      "project_count_max": 75
    },
    "large": {
      "revenue_min": 100000000,
      "revenue_max": 500000000,
      "headcount_min": 200,
      "headcount_max": 1000,
      "project_count_min": 50,
      "project_count_max": 200
    }
  },

  "chart_of_accounts": {
    "revenue": [
      {"code": "4000", "name": "Contract Revenue", "typical_pct": 0.95},
      {"code": "4100", "name": "Change Order Revenue", "typical_pct": 0.05}
    ],
    "cogs": [
      {"code": "5000", "name": "Direct Labor", "typical_pct": 0.25},
      {"code": "5100", "name": "Subcontractor Costs", "typical_pct": 0.40},
      {"code": "5200", "name": "Materials", "typical_pct": 0.15},
      {"code": "5300", "name": "Equipment Costs", "typical_pct": 0.05}
    ],
    "opex": [
      {"code": "6000", "name": "Project Management", "typical_pct": 0.03},
      {"code": "6100", "name": "Estimating & Bidding", "typical_pct": 0.02},
      {"code": "6200", "name": "General & Administrative", "typical_pct": 0.05},
      {"code": "6300", "name": "Insurance & Bonding", "typical_pct": 0.02}
    ],
    "assets": [
      {"code": "1000", "name": "Cash and Cash Equivalents"},
      {"code": "1100", "name": "Accounts Receivable - Progress Billings"},
      {"code": "1150", "name": "Retention Receivable"},
      {"code": "1200", "name": "Costs in Excess of Billings (WIP Asset)"},
      {"code": "1300", "name": "Prepaid Expenses"},
      {"code": "1400", "name": "Equipment"},
      {"code": "1500", "name": "Accumulated Depreciation"}
    ],
    "liabilities": [
      {"code": "2000", "name": "Accounts Payable - Trade"},
      {"code": "2050", "name": "Accounts Payable - Retention"},
      {"code": "2100", "name": "Accrued Expenses"},
      {"code": "2200", "name": "Billings in Excess of Costs (WIP Liability)"},
      {"code": "2300", "name": "Equipment Loans"},
      {"code": "2400", "name": "Line of Credit"}
    ],
    "equity": [
      {"code": "3000", "name": "Common Stock"},
      {"code": "3100", "name": "Retained Earnings"},
      {"code": "3200", "name": "Shareholder Distributions"}
    ]
  },

  "documents": {
    "operations": [
      "project_master",
      "contract_register",
      "wip_schedule",
      "percent_completion_schedule",
      "subcontractor_register",
      "change_order_log",
      "progress_billing_register"
    ],
    "financials": [
      "trial_balance",
      "income_statement",
      "balance_sheet",
      "cash_flow",
      "ar_aging",
      "ap_aging",
      "job_cost_detail"
    ]
  },

  "consistency_rules": [
    {
      "id": "wip_asset_calculation",
      "description": "WIP asset = Costs incurred - Billings (when costs > billings)",
      "check": "wip_schedule.costs_in_excess == balance_sheet.wip_asset"
    },
    {
      "id": "wip_liability_calculation",
      "description": "WIP liability = Billings - Costs incurred (when billings > costs)",
      "check": "wip_schedule.billings_in_excess == balance_sheet.wip_liability"
    },
    {
      "id": "project_revenue_tie",
      "description": "Sum of project revenue equals P&L contract revenue",
      "check": "sum(project_revenue) == income_statement.contract_revenue"
    },
    {
      "id": "retention_tie",
      "description": "Retention receivable ties to contract retention terms",
      "check": "retention_schedule.total == balance_sheet.retention_receivable"
    },
    {
      "id": "percent_complete_validation",
      "description": "Revenue recognized = Contract value × % complete",
      "check": "project.revenue_recognized == project.contract_value * project.percent_complete"
    }
  ],

  "seasonality_patterns": {
    "q1": 0.18,
    "q2": 0.28,
    "q3": 0.30,
    "q4": 0.24,
    "notes": "Weather-dependent; Q2-Q3 peak construction season"
  },

  "kpis": {
    "gross_margin": {"min": 0.12, "max": 0.25, "typical": 0.18},
    "backlog_months": {"min": 6, "max": 24, "typical": 12},
    "overbilled_pct": {"min": 0.0, "max": 0.15, "typical": 0.05},
    "underbilled_pct": {"min": 0.0, "max": 0.10, "typical": 0.03}
  },

  "qoe_adjustments": {
    "common": [
      "Percent complete methodology changes",
      "Unapproved change orders in revenue",
      "Warranty reserve adjustments",
      "Project loss provisions"
    ],
    "owner_addbacks": [
      "Owner vehicles and equipment personal use",
      "Related party subcontractor markups",
      "Owner-occupied property rent normalization"
    ]
  },

  "departments": [
    {"name": "Project Management", "typical_pct": 0.15},
    {"name": "Field Operations", "typical_pct": 0.50},
    {"name": "Estimating", "typical_pct": 0.10},
    {"name": "Administration", "typical_pct": 0.15},
    {"name": "Safety", "typical_pct": 0.05},
    {"name": "Executive", "typical_pct": 0.05}
  ]
}
