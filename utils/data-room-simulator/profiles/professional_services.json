{
  "industry": "professional_services",
  "display_name": "Professional Services",
  "revenue_model": "time_based",
  "description": "Time-based revenue with utilization tracking, WIP, billable hours, and engagement management",

  "bounds": {
    "small": {
      "revenue_min": 5000000,
      "revenue_max": 20000000,
      "headcount_min": 20,
      "headcount_max": 80,
      "client_count_min": 30,
      "client_count_max": 150
    },
    "mid": {
      "revenue_min": 20000000,
      "revenue_max": 100000000,
      "headcount_min": 70,
      "headcount_max": 350,
      "client_count_min": 100,
      "client_count_max": 500
    },
    "large": {
      "revenue_min": 100000000,
      "revenue_max": 500000000,
      "headcount_min": 300,
      "headcount_max": 1500,
      "client_count_min": 400,
      "client_count_max": 2000
    }
  },

  "chart_of_accounts": {
    "revenue": [
      {"code": "4000", "name": "Professional Fees", "typical_pct": 0.85},
      {"code": "4100", "name": "Retainer Revenue", "typical_pct": 0.10},
      {"code": "4200", "name": "Reimbursable Expenses", "typical_pct": 0.05}
    ],
    "cogs": [
      {"code": "5000", "name": "Professional Staff Salaries", "typical_pct": 0.40},
      {"code": "5100", "name": "Subcontractor Costs", "typical_pct": 0.08},
      {"code": "5200", "name": "Direct Project Costs", "typical_pct": 0.02}
    ],
    "opex": [
      {"code": "6000", "name": "Business Development", "typical_pct": 0.05},
      {"code": "6100", "name": "Professional Development", "typical_pct": 0.03},
      {"code": "6200", "name": "General & Administrative", "typical_pct": 0.12},
      {"code": "6300", "name": "Facility Costs", "typical_pct": 0.06},
      {"code": "6400", "name": "Technology & Software", "typical_pct": 0.04}
    ],
    "assets": [
      {"code": "1000", "name": "Cash and Cash Equivalents"},
      {"code": "1100", "name": "Accounts Receivable - Billed"},
      {"code": "1150", "name": "Unbilled Receivables (WIP)"},
      {"code": "1200", "name": "Prepaid Expenses"},
      {"code": "1300", "name": "Furniture & Equipment"},
      {"code": "1400", "name": "Accumulated Depreciation"}
    ],
    "liabilities": [
      {"code": "2000", "name": "Accounts Payable"},
      {"code": "2100", "name": "Accrued Expenses"},
      {"code": "2200", "name": "Accrued Compensation"},
      {"code": "2300", "name": "Deferred Revenue"},
      {"code": "2400", "name": "Line of Credit"}
    ],
    "equity": [
      {"code": "3000", "name": "Partner Capital"},
      {"code": "3100", "name": "Retained Earnings"},
      {"code": "3200", "name": "Partner Distributions"}
    ]
  },

  "documents": {
    "operations": [
      "client_master",
      "engagement_register",
      "timesheet_data",
      "wip_schedule",
      "invoice_register",
      "rate_card",
      "utilization_report"
    ],
    "financials": [
      "trial_balance",
      "income_statement",
      "balance_sheet",
      "cash_flow",
      "ar_aging",
      "ap_aging",
      "wip_aging"
    ]
  },

  "consistency_rules": [
    {
      "id": "billable_hours_revenue",
      "description": "Billable hours × effective rate = professional fees revenue",
      "check": "sum(hours * rate) == income_statement.professional_fees"
    },
    {
      "id": "wip_tie",
      "description": "WIP schedule ending balance ties to unbilled receivables",
      "check": "wip_schedule.ending_balance == balance_sheet.unbilled_receivables"
    },
    {
      "id": "utilization_calculation",
      "description": "Utilization = Billable hours / Available hours",
      "check": "utilization == billable_hours / available_hours"
    },
    {
      "id": "realization_rate",
      "description": "Realization = Collected / Standard billing",
      "check": "realization == actual_collected / standard_billing"
    }
  ],

  "seasonality_patterns": {
    "q1": 0.27,
    "q2": 0.26,
    "q3": 0.21,
    "q4": 0.26,
    "notes": "Q3 summer slowdown; Q1/Q4 busy with year-end work"
  },

  "kpis": {
    "gross_margin": {"min": 0.40, "max": 0.60, "typical": 0.50},
    "utilization_rate": {"min": 0.60, "max": 0.85, "typical": 0.72},
    "realization_rate": {"min": 0.85, "max": 1.0, "typical": 0.92},
    "revenue_per_employee": {"min": 150000, "max": 300000, "typical": 200000}
  },

  "qoe_adjustments": {
    "common": [
      "WIP write-offs / bad debt",
      "Partner compensation normalization",
      "Revenue recognition timing (milestone vs. time)",
      "Non-recurring project costs"
    ],
    "owner_addbacks": [
      "Above-market partner compensation",
      "Partner perquisites (auto, travel)",
      "Related party rent"
    ]
  },

  "departments": [
    {"name": "Professional Staff", "typical_pct": 0.65},
    {"name": "Business Development", "typical_pct": 0.10},
    {"name": "Administration", "typical_pct": 0.15},
    {"name": "IT & Operations", "typical_pct": 0.05},
    {"name": "Executive", "typical_pct": 0.05}
  ],

  "staff_levels": [
    {"level": "Partner", "typical_pct": 0.10, "utilization_target": 0.50, "rate_multiplier": 3.0},
    {"level": "Director", "typical_pct": 0.15, "utilization_target": 0.65, "rate_multiplier": 2.0},
    {"level": "Manager", "typical_pct": 0.25, "utilization_target": 0.75, "rate_multiplier": 1.5},
    {"level": "Senior Associate", "typical_pct": 0.25, "utilization_target": 0.80, "rate_multiplier": 1.2},
    {"level": "Associate", "typical_pct": 0.25, "utilization_target": 0.85, "rate_multiplier": 1.0}
  ]
}
