    if not text:
        continue

    is_heading = looks_like_heading(text, alias_phrases, thresholds)

    # Exclude cover/engagement pages from content unless the line is a canonical heading.
    if row.page_or_slide <= 5 and not is_heading:
        continue

    if any(p.search(text) for p in ban_patterns):
        continue

    # Drop table/grid-like and overly numeric fragments unless it is a heading.
    digit_ratio = sum(ch.isdigit() for ch in text) / max(len(text), 1)
    if not is_heading and (looks_like_table_row(text) or digit_ratio > 0.20):
        continue

    # Drop tiny glossary/navigation fragments unless they are headings.
    words = text.split()
    if not is_heading and (len(words) <= 2 or len(text) < 16):
        continue

    cleaned.append(row)

mapping_result = assign_sections(
    lines=cleaned,
    canonical_sections=CANONICAL_SECTION_ORDER,
    section_aliases=SECTION_ALIASES,
    thresholds=thresholds,
)

