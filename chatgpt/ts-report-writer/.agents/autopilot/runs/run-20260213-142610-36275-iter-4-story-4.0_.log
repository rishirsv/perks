    heading_max_digit_ratio=THRESHOLDS.heading_max_digit_ratio,
)
alias_phrases, _ = build_alias_lookup(CANONICAL_SECTION_ORDER, SECTION_ALIASES)

rows = []
for line in catalog_path.read_text(encoding='utf-8', errors='ignore').splitlines():
