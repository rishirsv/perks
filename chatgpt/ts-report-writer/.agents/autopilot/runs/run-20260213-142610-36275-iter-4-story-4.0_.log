    report_id=report_id,
    source_file=source_file,
    sections=mapping_result.sections,
    heading_hits=mapping_result.heading_hits,
    section_order=CANONICAL_SECTION_ORDER,
    extra_metadata={
        'VERBATIM_MODE': 'strict',
        'EVIDENCE_PROFILE': 'full',
        'FAIL_CLOSED': 'true',
    },
)

# Build template-required source evidence + coverage map block without untraced bullet content.
source_manifest = verif_dir / 'source-text' / 'manifest.json'
manifest = json.loads(source_manifest.read_text(encoding='utf-8'))
files = manifest.get('files', [])
if files:
