    '- "'`OCR_SLIDES`: []'"',
    f\"- "'`OCR_ARTIFACTS_DIR`: extracted/verification/{report_id}/source-text/ocr",
    f"- `OCR_RUN_METADATA`: extracted/verification/{report_id}/source-text/ocr/ocr-run.json",
    f"- `PROVENANCE_QA_JSON`: extracted/verification/{report_id}/qa/provenance.json",
    '"'- "'`PROVENANCE_STATUS`: pending'"',
    f\"- "'`GATES_QA_JSON`: extracted/verification/{report_id}/qa/gates.json",
    '"'- "'`GATES_STATUS`: pending'"',
    f\"- "'`SECTION_MAP_JSON`: extracted/verification/{report_id}/mapping/section-map.json",
    f"- `SECTION_ACCOUNTING_JSON`: extracted/verification/{report_id}/mapping/section-accounting.json",
    f"- `RENDER_TRACE_JSON`: extracted/verification/{report_id}/render/render-trace.json",
    '"'',
    '## Source-to-Extraction Coverage Map',
    '',
    '| Canonical Section | Source slide/page IDs | Source evidence files | Extracted reference(s) | Notes |',
    '|---|---|---|---|---|',
]

for section in CANONICAL_SECTION_ORDER:
    entries = mapping_result.sections.get(section, [])
    if entries:
        pages = sorted({e.page_or_slide for e in entries})
        page_ids = ', '.join(str(p) for p in pages[:12]) + (' ...' if len(pages) > 12 else '')
        evidence_files = ', '.join(f'"'`page-{p:03d}.txt`'"' for p in pages[:4]) + (' ...' if len(pages) > 4 else '')
        notes = 'Report-body lines retained after full cleanup; legal/table/navigation fragments excluded.'
    else:
        page_ids = 'N/A'
        evidence_files = 'N/A'
        notes = 'Not present in source report.'
    coverage_lines.append(f\"| {section} | {page_ids} | {evidence_files} | "'`# {section}` | {notes} |")

coverage_lines.append('"'')

base_lines = render_output.markdown.splitlines()
try:
    first_section_idx = base_lines.index('# Executive Summary')
except ValueError:
    first_section_idx = len(base_lines)

new_lines = base_lines[:first_section_idx] + coverage_lines + base_lines[first_section_idx:]
insert_count = len(coverage_lines)

# Shift trace line numbers by inserted line count (all trace rows occur after first section heading).
new_trace = []
for row in render_output.trace:
    r = dict(row)
    if int(r.get('markdown_line_number', 0)) >= first_section_idx + 1:
        r['markdown_line_number'] = int(r['markdown_line_number']) + insert_count
    new_trace.append(r)

markdown_out.write_text('\\n'.join(new_lines).rstrip() + '\\n', encoding='utf-8')
write_jsonl(selected_out, cleaned)
write_json(render_trace_out, new_trace)

section_accounting = build_section_accounting(mapping_result.sections, new_trace)
write_json(section_accounting_out, section_accounting)
write_json(
    section_map_out,
