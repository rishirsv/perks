        'report_id': report_id,
        'heading_hits': mapping_result.heading_hits,
        'heading_events': mapping_result.heading_events,
        'unresolved_headings': mapping_result.unresolved_headings,
        'section_disposition': render_output.section_disposition,
        'section_accounting_status': section_accounting['status'],
    },
)

if verification_json_path.exists():
    verification_payload = json.loads(verification_json_path.read_text(encoding='utf-8'))
    counts = section_counts(mapping_result.sections)
    verification_payload['section_coverage'] = counts
    verification_payload['section_disposition'] = render_output.section_disposition
    verification_payload['missing_sections'] = [sec for sec, count in counts.items() if count == 0]
    verification_payload['updated_at'] = datetime.utcnow().isoformat() + 'Z'
    write_json(verification_json_path, verification_payload)

print(f'Cleaned selected lines: {len(cleaned)}')
print(f'Render trace lines: {len(new_trace)}')
