import json
from pathlib import Path
from ts_report_writer.catalog import CatalogLine
from ts_report_writer.constants import CANONICAL_SECTION_ORDER, SECTION_ALIASES, THRESHOLDS
from ts_report_writer.mapping import MappingThresholds, assign_sections

report_id = 'project-coffee-buy-side-fdd'
source_file = 'Project Coffee_buy side_FDD .pptx'
md_path = Path('extracted') / f'{report_id}.md'
selected_path = Path('extracted/verification') / report_id / 'catalog/selected-lines.jsonl'
prov_path = Path('extracted/verification') / report_id / 'qa/provenance.json'
gates_path = Path('extracted/verification') / report_id / 'qa/gates.json'

rows = [json.loads(l) for l in selected_path.read_text(encoding='utf-8').splitlines() if l.strip()]
lines = [CatalogLine(**r) for r in rows]
thresholds = MappingThresholds(
    heading_fuzzy_match_min=THRESHOLDS.heading_fuzzy_match_min,
    heading_max_words=THRESHOLDS.heading_max_words,
    heading_max_chars=THRESHOLDS.heading_max_chars,
    heading_max_digit_ratio=THRESHOLDS.heading_max_digit_ratio,
)
mapping = assign_sections(lines=lines, canonical_sections=CANONICAL_SECTION_ORDER, section_aliases=SECTION_ALIASES, thresholds=thresholds)

md = md_path.read_text(encoding='utf-8')
marker = '\\n# Executive Summary\\n'
if marker not in md:
    raise SystemExit('Executive Summary marker not found')
_, rest = md.split(marker, 1)

prov_status = json.loads(prov_path.read_text(encoding='utf-8')).get('status', 'needs_revision') if prov_path.exists() else 'needs_revision'
gates_status = json.loads(gates_path.read_text(encoding='utf-8')).get('status', 'needs_revision') if gates_path.exists() else 'needs_revision'

rows_md = []
for section in CANONICAL_SECTION_ORDER:
    sec_lines = mapping.sections.get(section, [])
    if not sec_lines:
        rows_md.append(f\"| {section} | N/A | N/A | "'`# {section}` | Not present in source report. |")
        continue
    slide_ids = sorted({ln.page_or_slide for ln in sec_lines if ln.page_or_slide})
    slide_label = ", ".join(str(i) for i in slide_ids)
    file_label = ", ".join(f"`slide-{i:03d}.txt`" for i in slide_ids[:4])
    if len(slide_ids) > 4:
        file_label += " ..."
    rows_md.append(
        f"| {section} | {slide_label} | {file_label} | `# {section}` | Full-report cleanup pass applied; retained only source-backed body lines. |"
    )

header = f"""# Report Extraction: {report_id}

## Report Metadata

- `SOURCE_FILE`: {source_file}
- `REPORT_ID`: {report_id}
- `SOURCE_PATH`: reports/{source_file}
- `EXTRACTION_STATUS`: extracted_pending_verification
