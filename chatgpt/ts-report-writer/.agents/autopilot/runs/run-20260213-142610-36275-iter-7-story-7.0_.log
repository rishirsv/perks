def markdown_section(markdown_text: str, heading: str) -> str:
    pattern = rf"(?ms)^# {re.escape(heading)}\n(.*?)(?=^# |\Z)"
    match = re.search(pattern, markdown_text)
    if not match:
        return ""
    return match.group(1)


