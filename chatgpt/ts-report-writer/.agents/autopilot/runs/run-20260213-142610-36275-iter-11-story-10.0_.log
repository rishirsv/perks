import json
import re
from pathlib import Path
from ts_report_writer.catalog import CatalogLine, write_json, write_jsonl
from ts_report_writer.constants import CANONICAL_SECTION_ORDER, SECTION_ALIASES, THRESHOLDS
from ts_report_writer.mapping import MappingThresholds, assign_sections
from ts_report_writer.render import render_markdown
from ts_report_writer.pipeline import build_section_accounting

report_id = 'project-ed-buy-side-fdd'
source_file = 'Project Ed_buy side_FDD.pptx'
root = Path('.').resolve()
verification_dir = root / 'extracted' / 'verification' / report_id
selected_path = verification_dir / 'catalog' / 'selected-lines.jsonl'
render_trace_path = verification_dir / 'render' / 'render-trace.json'
section_map_path = verification_dir / 'mapping' / 'section-map.json'
section_accounting_path = verification_dir / 'mapping' / 'section-accounting.json'
output_md_path = root / 'extracted' / f'{report_id}.md'

rows = [json.loads(line) for line in selected_path.read_text(encoding='utf-8').splitlines() if line.strip()]

boilerplate = re.compile(
    r\"important notice|dear directors|engagement|private and confidential|all rights reserved|prepared solely|letterhead|yours faithfully|yours sincerely\",
    re.IGNORECASE,
)
obvious_noise = re.compile(r\""'^(page|pages|ttm|ytd|source:?)$", re.IGNORECASE)


def keep_text(text: str) -> bool:
    t = text.strip()
    if not t:
        return False
    if boilerplate.search(t):
        return False
    if t.lower().startswith('"'read more'):
        return False
    if t.endswith(':'):
        return False

    words = re.findall(r\"[A-Za-z0-9']+\", t)
    if len(words) < 8:
        return False
    if obvious_noise.match(t):
        return False
    if not re.search(r'[A-Za-z]', t):
        return False
    if not re.search(r'[."'!?)]$'"', t):
        return False
    if re.match(r'"'^[a-z]'"', t):
        return False
    if re.match(r'"'^[,.;:]'"', t):
        return False

    # Drop lines that are mostly placeholders/tokens rather than body text.
    placeholder_tokens = len(re.findall(r\"\\[["'^'"\\]]+\\]\", t))
    if placeholder_tokens >= 3 and len(words) <= 14:
        return False

    return True

clean_rows = [row for row in rows if keep_text(str(row.get('text_raw', '')))]

# De-duplicate adjacent text repeats after filtering.
filtered_rows = []
last_norm = None
for row in clean_rows:
    norm = str(row.get('text_norm') or '').strip().lower()
    if norm and norm == last_norm:
        continue
    filtered_rows.append(row)
    last_norm = norm if norm else last_norm

lines: list[CatalogLine] = []
for row in filtered_rows:
    lines.append(
        CatalogLine(
            line_id=str(row.get('line_id', '')),
            text_raw=str(row.get('text_raw', '')),
            text_norm=str(row.get('text_norm', '')),
            source_kind=str(row.get('source_kind', '')),
            source_file=str(row.get('source_file', source_file)),
            page_or_slide=int(row.get('page_or_slide', 0)),
            bbox=row.get('bbox'),
            class_flags=list(row.get('class_flags', [])),
            included_candidate=bool(row.get('included_candidate', True)),
            exclusion_reason=row.get('exclusion_reason'),
            section_candidate=row.get('section_candidate'),
            section_confidence=int(row.get('section_confidence', 0)),
            metadata=dict(row.get('metadata', {})),
        )
    )

mapping_result = assign_sections(
    lines=lines,
    canonical_sections=CANONICAL_SECTION_ORDER,
    section_aliases=SECTION_ALIASES,
    thresholds=MappingThresholds(
        heading_fuzzy_match_min=THRESHOLDS.heading_fuzzy_match_min,
        heading_max_words=THRESHOLDS.heading_max_words,
        heading_max_chars=THRESHOLDS.heading_max_chars,
        heading_max_digit_ratio=THRESHOLDS.heading_max_digit_ratio,
    ),
)

render_output = render_markdown(
    report_id=report_id,
    source_file=source_file,
    sections=mapping_result.sections,
    heading_hits=mapping_result.heading_hits,
    section_order=CANONICAL_SECTION_ORDER,
    extra_metadata={
        'VERBATIM_MODE': 'strict',
        'EVIDENCE_PROFILE': 'full',
        'FAIL_CLOSED': 'true',
    },
)
section_accounting = build_section_accounting(mapping_result.sections, render_output.trace)

output_md_path.write_text(render_output.markdown, encoding='utf-8')
write_jsonl(selected_path, lines)
write_json(render_trace_path, render_output.trace)
write_json(section_accounting_path, section_accounting)
write_json(
    section_map_path,
    {
        'report_id': report_id,
        'heading_hits': mapping_result.heading_hits,
        'heading_events': mapping_result.heading_events,
        'unresolved_headings': mapping_result.unresolved_headings,
        'section_disposition': render_output.section_disposition,
        'section_accounting_status': section_accounting['status'],
    },
)

print({'original_selected': len(rows), 'clean_selected': len(lines)})
