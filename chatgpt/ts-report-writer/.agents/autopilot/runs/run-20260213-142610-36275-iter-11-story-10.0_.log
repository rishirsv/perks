output_md_path = root / 'extracted' / f'{report_id}.md'

rows = [json.loads(line) for line in line_catalog_path.read_text(encoding='utf-8').splitlines() if line.strip()]

bad_pattern = re.compile(
    r\"important notice|engagement letter|prepared solely|no assurance opinion|does not constitute an audit|\"
    r\"benchmark|virtual data room|scope of work|procedures we performed|non-reliance|all rights reserved|\"
    r\"member firm|for illustrative purposes|confidentiality notice|yours faithfully|yours sincerely\",
    re.IGNORECASE,
)

def keep_row(row: dict) -> bool:
    if not bool(row.get('included_candidate', True)):
        return False
    if str(row.get('source_kind', '')) "'!= '"'pptx_xml':
        return False

    slide = int(row.get('page_or_slide', 0) or 0)
    if slide < 10 or slide > 120:
        return False

    text = str(row.get('text_raw', '')).strip()
    if not text:
        return False
    if bad_pattern.search(text):
        return False
    if text.lower().startswith('read more'):
        return False
    if text.endswith(':'):
        return False
    if re.match(r'"'^[,.;:]'"', text):
        return False

    words = re.findall(r\"[A-Za-z0-9']+\", text)
    if len(words) < 9:
        return False
    if not re.search(r'[A-Za-z]', text):
        return False
    if not re.search(r'[."'!?)]$'"', text):
        return False
    if re.match(r'"'^[a-z]'"', text):
        return False

    return True

filtered_rows = [row for row in rows if keep_row(row)]

# De-duplicate by line id / adjacent normalized text.
seen_ids = set()
clean_rows = []
last_norm = None
for row in filtered_rows:
    line_id = str(row.get('line_id', ''))
    if line_id in seen_ids:
        continue
    norm = str(row.get('text_norm', '')).strip().lower()
    if norm and norm == last_norm:
        continue
    clean_rows.append(row)
    seen_ids.add(line_id)
    if norm:
        last_norm = norm

lines: list[CatalogLine] = []
for row in clean_rows:
    lines.append(
        CatalogLine(
            line_id=str(row.get('line_id', '')),
            text_raw=str(row.get('text_raw', '')),
            text_norm=str(row.get('text_norm', '')),
            source_kind=str(row.get('source_kind', '')),
            source_file=str(row.get('source_file', source_file)),
            page_or_slide=int(row.get('page_or_slide', 0)),
            bbox=row.get('bbox'),
            class_flags=list(row.get('class_flags', [])),
            included_candidate=bool(row.get('included_candidate', True)),
            exclusion_reason=row.get('exclusion_reason'),
            section_candidate=row.get('section_candidate'),
            section_confidence=int(row.get('section_confidence', 0)),
            metadata=dict(row.get('metadata', {})),
        )
    )

mapping_result = assign_sections(
    lines=lines,
    canonical_sections=CANONICAL_SECTION_ORDER,
    section_aliases=SECTION_ALIASES,
    thresholds=MappingThresholds(
        heading_fuzzy_match_min=THRESHOLDS.heading_fuzzy_match_min,
        heading_max_words=THRESHOLDS.heading_max_words,
        heading_max_chars=THRESHOLDS.heading_max_chars,
        heading_max_digit_ratio=THRESHOLDS.heading_max_digit_ratio,
    ),
)

render_output = render_markdown(
    report_id=report_id,
    source_file=source_file,
    sections=mapping_result.sections,
    heading_hits=mapping_result.heading_hits,
    section_order=CANONICAL_SECTION_ORDER,
    extra_metadata={
        'VERBATIM_MODE': 'strict',
        'EVIDENCE_PROFILE': 'full',
        'FAIL_CLOSED': 'true',
    },
)
section_accounting = build_section_accounting(mapping_result.sections, render_output.trace)

# Build required-source-evidence + coverage map block per template.
trace_by_section: dict[str, list[dict]] = {sec: [] for sec in CANONICAL_SECTION_ORDER}
for row in render_output.trace:
    sec = str(row.get('section', ''))
    if sec in trace_by_section:
        trace_by_section[sec].append(row)

coverage_lines = [
    '## Source-to-Extraction Coverage Map',
    '',
    '| Canonical Section | Source slide/page IDs | Source evidence files | Extracted reference(s) | Notes |',
    '|---|---|---|---|---|',
]

for section in CANONICAL_SECTION_ORDER:
    rows_for_section = trace_by_section.get(section, [])
    if rows_for_section:
        slide_ids = sorted({int(r.get('page_or_slide', 0)) for r in rows_for_section if int(r.get('page_or_slide', 0)) > 0})
        slide_label = ', '.join(f'S{sid:03d}' for sid in slide_ids)
        files = sorted({f\"slide-{sid:03d}.txt\" for sid in slide_ids})
        file_label = ', '.join(files[:8]) + (' ...' if len(files) > 8 else '')
        note = 'Retained verbatim body-text lines after full-report cleanup.'
    else:
        slide_label = 'N/A'
        file_label = 'N/A'
        note = 'Not present in source report.'
    ref = f'"'`# {section}`'"'
    coverage_lines.append(f'| {section} | {slide_label} | {file_label} | {ref} | {note} |')

base_md = render_output.markdown
section_start = base_md.find('\\n# Executive Summary\\n')
if section_start == -1:
    section_start = base_md.find('# Executive Summary\\n')

sections_body = base_md[section_start + 1 :] if section_start "'!= -1 else base_md

header = [
    f'"'# Report Extraction: {report_id}',
    '',
    '## Report Metadata',
    '',
    f'- "'`SOURCE_FILE`: {source_file}'"',
    f'- "'`REPORT_ID`: {report_id}'"',
    f'- "'`SOURCE_PATH`: reports/{source_file}'"',
    '- "'`EXTRACTION_STATUS`: extracted_pending_verification'"',
    f'- "'`EXTRACTION_DATE`: {date.today().isoformat()}'"',
    '',
    '## Required Source Evidence',
    '',
    f'- "'`SOURCE_TEXT_DIR`: extracted/verification/{report_id}/source-text/pptx'"',
    f'- "'`MONTAGE_DIR`: extracted/verification/{report_id}/montage'"',
    '- "'`SOURCE_ARTIFACTS`: slide-001.txt ... slide-178.txt'"',
    '- "'`OCR_USED`: false'"',
    '- "'`OCR_SLIDES`: []'"',
    f'- "'`OCR_ARTIFACTS_DIR`: extracted/verification/{report_id}/source-text/ocr'"',
    f'- "'`OCR_RUN_METADATA`: extracted/verification/{report_id}/source-text/ocr/ocr-run.json'"',
    f'- "'`PROVENANCE_QA_JSON`: extracted/verification/{report_id}/qa/provenance.json'"',
    '- "'`PROVENANCE_STATUS`: pending'"',
    f'- "'`GATES_QA_JSON`: extracted/verification/{report_id}/qa/gates.json'"',
    '- "'`GATES_STATUS`: pending'"',
    f'- "'`SECTION_MAP_JSON`: extracted/verification/{report_id}/mapping/section-map.json'"',
    f'- "'`SECTION_ACCOUNTING_JSON`: extracted/verification/{report_id}/mapping/section-accounting.json'"',
    f'- "'`RENDER_TRACE_JSON`: extracted/verification/{report_id}/render/render-trace.json'"',
    '',
] + coverage_lines + ['', sections_body.rstrip(), '']

final_markdown = '\\n'.join(header)

output_md_path.write_text(final_markdown, encoding='utf-8')
write_jsonl(selected_path, lines)
write_json(render_trace_path, render_output.trace)
write_json(section_accounting_path, section_accounting)
write_json(
    section_map_path,
    {
        'report_id': report_id,
        'heading_hits': mapping_result.heading_hits,
        'heading_events': mapping_result.heading_events,
        'unresolved_headings': mapping_result.unresolved_headings,
        'section_disposition': render_output.section_disposition,
        'section_accounting_status': section_accounting['status'],
    },
)

print({'selected_lines': len(lines), 'trace_lines': len(render_output.trace)})
