{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kpmg-slidegen.local/schemas/deckSpec.schema.json",
  "title": "DeckSpec",
  "type": "object",
  "required": [
    "slides"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "subject": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "author": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "company": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "year": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1900,
              "maximum": 3000
            },
            {
              "$ref": "#/$defs/nonEmptyString"
            }
          ]
        },
        "footer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "year": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1900,
                  "maximum": 3000
                },
                {
                  "$ref": "#/$defs/nonEmptyString"
                }
              ]
            },
            "legalEntityName": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "jurisdiction": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "legalStructure": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "documentClassification": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "officeContactText": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        },
        "allowSparse": {
          "type": "boolean"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "placeholders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slide"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "notesValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      ]
    },
    "textItem": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "header": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "textArrayMin1": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/textItem"
      }
    },
    "textArrayMin2": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/textItem"
      }
    },
    "textArrayMin3": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/textItem"
      }
    },
    "textArrayMin4": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/textItem"
      }
    },
    "stringArrayMin2": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "values"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": [
              "number",
              "string"
            ]
          }
        }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "data": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/chartSeries"
          }
        },
        "opts": {
          "type": "object",
          "additionalProperties": true
        },
        "source": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headers",
        "rows"
      ],
      "properties": {
        "headers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": [
              "string",
              "number"
            ]
          }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        }
      }
    },
    "kpi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "label"
      ],
      "properties": {
        "value": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "delta": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "heading": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "body": {
          "$ref": "#/$defs/textArrayMin1"
        }
      },
      "anyOf": [
        {
          "required": [
            "heading"
          ]
        },
        {
          "required": [
            "title"
          ]
        },
        {
          "required": [
            "body"
          ]
        }
      ]
    },
    "contentsSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "title",
        "items"
      ],
      "properties": {
        "number": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "pageRange": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "variant": {
      "type": "string",
      "enum": [
        "dark",
        "light"
      ]
    },
    "slideBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "cover",
            "contents",
            "analysisWideChartTableTextScaffold",
            "dividerDark",
            "divider",
            "dividerLight",
            "analysisWideChart2ColsText",
            "analysisWideChartTableText",
            "analysisNarrowTable",
            "twoColumnText",
            "analysis2ColumnsText",
            "oneColumnText",
            "titleStrapline4TextBoxes",
            "qualityOfEarnings",
            "backCover"
          ]
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "subtitle": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "strapline": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "heading": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sectionNumber": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "sectionTitle": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "variant": {
          "$ref": "#/$defs/variant"
        },
        "body": {
          "$ref": "#/$defs/textArrayMin1"
        },
        "leftBody": {
          "$ref": "#/$defs/textArrayMin1"
        },
        "rightBody": {
          "$ref": "#/$defs/textArrayMin1"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/column"
          }
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contentsSection"
          }
        },
        "sectionsTop": {
          "$ref": "#/$defs/stringArrayMin2"
        },
        "sectionsBottom": {
          "$ref": "#/$defs/stringArrayMin2"
        },
        "kpis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/kpi"
          }
        },
        "table": {
          "$ref": "#/$defs/table"
        },
        "chart": {
          "$ref": "#/$defs/chart"
        },
        "noteSource": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "insightTitle": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "notes": {
          "$ref": "#/$defs/notesValue"
        },
        "disclaimer": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "url": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "slideCover": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "cover"
            }
          },
          "required": [
            "type",
            "title",
            "subtitle"
          ]
        }
      ]
    },
    "slideContents": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "contents"
            },
            "sections": {
              "type": "array",
              "minItems": 8,
              "items": {
                "$ref": "#/$defs/contentsSection"
              }
            }
          },
          "required": [
            "type",
            "title",
            "sections"
          ]
        }
      ]
    },
    "slideDivider": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "enum": [
                "divider",
                "dividerDark",
                "dividerLight"
              ]
            }
          },
          "required": [
            "type",
            "sectionNumber",
            "sectionTitle"
          ]
        }
      ]
    },
    "slideText2Col": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "enum": [
                "twoColumnText",
                "analysis2ColumnsText"
              ]
            },
            "leftBody": {
              "$ref": "#/$defs/textArrayMin2"
            },
            "rightBody": {
              "$ref": "#/$defs/textArrayMin2"
            }
          },
          "required": [
            "type",
            "title",
            "leftBody",
            "rightBody"
          ]
        }
      ]
    },
    "slideOneCol": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "oneColumnText"
            },
            "body": {
              "$ref": "#/$defs/textArrayMin3"
            }
          },
          "required": [
            "type",
            "title",
            "body"
          ]
        }
      ]
    },
    "slideQoe": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "qualityOfEarnings"
            }
          },
          "required": [
            "type",
            "title"
          ]
        }
      ]
    },
    "slideChartText": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "enum": [
                "analysisWideChart2ColsText",
                "analysisWideChartTableText"
              ]
            },
            "body": {
              "$ref": "#/$defs/textArrayMin4"
            },
            "chart": {
              "$ref": "#/$defs/chart"
            }
          },
          "required": [
            "type",
            "title",
            "body",
            "chart"
          ]
        }
      ]
    },
    "slideTable": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "analysisNarrowTable"
            },
            "table": {
              "$ref": "#/$defs/table"
            }
          },
          "required": [
            "type",
            "title",
            "table"
          ]
        }
      ]
    },
    "slide4Cols": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "titleStrapline4TextBoxes"
            },
            "columns": {
              "type": "array",
              "minItems": 4,
              "items": {
                "$ref": "#/$defs/column"
              }
            }
          },
          "required": [
            "type",
            "title",
            "columns"
          ]
        }
      ]
    },
    "slideScaffoldPnl": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "analysisWideChartTableTextScaffold"
            }
          },
          "required": [
            "type",
            "title"
          ]
        }
      ]
    },
    "slideBackCover": {
      "allOf": [
        {
          "$ref": "#/$defs/slideBase"
        },
        {
          "properties": {
            "type": {
              "const": "backCover"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
    "slide": {
      "oneOf": [
        {
          "$ref": "#/$defs/slideCover"
        },
        {
          "$ref": "#/$defs/slideContents"
        },
        {
          "$ref": "#/$defs/slideDivider"
        },
        {
          "$ref": "#/$defs/slideText2Col"
        },
        {
          "$ref": "#/$defs/slideOneCol"
        },
        {
          "$ref": "#/$defs/slideQoe"
        },
        {
          "$ref": "#/$defs/slideChartText"
        },
        {
          "$ref": "#/$defs/slideTable"
        },
        {
          "$ref": "#/$defs/slide4Cols"
        },
        {
          "$ref": "#/$defs/slideScaffoldPnl"
        },
        {
          "$ref": "#/$defs/slideBackCover"
        }
      ]
    }
  }
}
