{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kpmg-slidegen/deckspec-slots-schema",
  "title": "KPMG SlideGen DeckSpec Slots Schema",
  "description": "Machine-readable slot contract for authoring deckSpec JSON without inspecting builders.",
  "type": "object",
  "additionalProperties": false,
  "required": ["slides"],
  "properties": {
    "metadata": { "$ref": "#/$defs/metadata" },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide" }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "company": { "type": "string", "minLength": 1 },
        "subject": { "type": "string", "minLength": 1 },
        "allowSparse": { "type": "boolean" },
        "year": { "type": "number" },
        "jurisdiction": { "type": "string" },
        "legalStructure": { "type": "string" },
        "documentClassification": { "type": "string" },
        "officeContactText": { "type": "string" },
        "footer": { "$ref": "#/$defs/footer" }
      }
    },
    "footer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "year": { "type": "number" },
        "legalEntityName": { "type": "string", "minLength": 1 },
        "jurisdiction": { "type": "string", "minLength": 1 },
        "legalStructure": { "type": "string", "minLength": 1 },
        "documentClassification": { "type": "string" },
        "officeContactText": { "type": "string" }
      }
    },
    "bodyStyle": {
      "type": "string",
      "enum": ["bullets", "paragraphs"]
    },
    "textRun": {
      "description": "Allowed item in textArray slots.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": { "type": "string", "minLength": 1 },
            "subheader": { "type": "boolean" },
            "header": { "type": "boolean" }
          }
        }
      ]
    },
    "textArrayMin1": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/textRun" }
    },
    "textArrayMin2": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/textRun" }
    },
    "textArrayMin3": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/textRun" }
    },
    "textArrayMin4": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/textRun" }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headers", "rows"],
      "properties": {
        "title": { "type": "string" },
        "heading": { "type": "string" },
        "headers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "items": {
              "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }, { "type": "null" }]
            }
          }
        }
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["values"],
      "properties": {
        "name": { "type": "string" },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [{ "type": "number" }, { "type": "integer" }]
          }
        }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "data"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bar", "bar3d", "line", "pie", "doughnut", "area", "scatter", "radar"]
        },
        "data": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/chartSeries" }
        },
        "opts": {
          "type": "object",
          "description": "Pptx chart options pass-through for renderer customization."
        },
        "source": {
          "type": "string",
          "minLength": 0,
          "maxLength": 700
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "heading": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "body": { "$ref": "#/$defs/textArrayMin1" }
      },
      "anyOf": [{ "required": ["heading"] }, { "required": ["title"] }]
    },
    "columnsMin4": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/column" }
    },
    "contentsSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "title"],
      "properties": {
        "number": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pageRange": { "type": "string" }
      }
    },
    "contentsSectionsMin8": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/contentsSection" }
    },
    "slideCover": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "subtitle"],
      "properties": {
        "type": { "const": "cover" },
        "title": { "type": "string", "minLength": 8, "maxLength": 100 },
        "subtitle": { "type": "string", "minLength": 12, "maxLength": 200 }
      }
    },
    "slideDivider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "sectionNumber", "sectionTitle"],
      "properties": {
        "type": { "const": "divider" },
        "sectionNumber": { "type": "string", "pattern": "^\\d{2}$", "minLength": 2, "maxLength": 2 },
        "sectionTitle": { "type": "string", "minLength": 6, "maxLength": 80 }
      }
    },
    "slideDividerDark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "sectionNumber", "sectionTitle"],
      "properties": {
        "type": { "const": "dividerDark" },
        "sectionNumber": { "type": "string", "pattern": "^\\d{2}$", "minLength": 2, "maxLength": 2 },
        "sectionTitle": { "type": "string", "minLength": 6, "maxLength": 80 }
      }
    },
    "slideDividerLight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "sectionNumber", "sectionTitle"],
      "properties": {
        "type": { "const": "dividerLight" },
        "sectionNumber": { "type": "string", "pattern": "^\\d{2}$", "minLength": 2, "maxLength": 2 },
        "sectionTitle": { "type": "string", "minLength": 6, "maxLength": 80 }
      }
    },
    "slideContents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "sections"],
      "properties": {
        "type": { "const": "contents" },
        "title": { "type": "string", "minLength": 6, "maxLength": 40 },
        "sections": { "$ref": "#/$defs/contentsSectionsMin8" }
      }
    },
    "slideOneColumnText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "body"],
      "properties": {
        "type": { "const": "oneColumnText" },
        "title": { "type": "string", "minLength": 12, "maxLength": 50 },
        "strapline": { "type": "string", "minLength": 12, "maxLength": 700 },
        "source": { "type": "string", "minLength": 12, "maxLength": 700 },
        "bodyStyle": { "$ref": "#/$defs/bodyStyle" },
        "body": {
          "$ref": "#/$defs/textArrayMin3",
          "x-kpmg-minChars": 180
        }
      }
    },
    "slideTwoColumnText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "leftBody", "rightBody"],
      "properties": {
        "type": { "const": "twoColumnText" },
        "title": { "type": "string", "minLength": 12, "maxLength": 50 },
        "strapline": { "type": "string", "minLength": 12, "maxLength": 700 },
        "bodyStyle": { "$ref": "#/$defs/bodyStyle" },
        "leftBody": {
          "$ref": "#/$defs/textArrayMin2",
          "x-kpmg-minChars": 80
        },
        "rightBody": {
          "$ref": "#/$defs/textArrayMin2",
          "x-kpmg-minChars": 80
        }
      }
    },
    "slideAnalysisNarrowTable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "table", "insights"],
      "properties": {
        "type": { "const": "analysisNarrowTable" },
        "title": { "type": "string", "minLength": 12, "maxLength": 50 },
        "strapline": { "type": "string", "minLength": 12, "maxLength": 700 },
        "notes": { "type": "string", "minLength": 12, "maxLength": 700 },
        "insightTitle": { "type": "string", "minLength": 6, "maxLength": 80 },
        "insights": {
          "$ref": "#/$defs/textArrayMin2",
          "x-kpmg-minChars": 80
        },
        "table": { "$ref": "#/$defs/table" }
      }
    },
    "slideAnalysisWideChart2ColsText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "body", "chart"],
      "properties": {
        "type": { "const": "analysisWideChart2ColsText" },
        "title": { "type": "string", "minLength": 12, "maxLength": 50 },
        "strapline": { "type": "string", "minLength": 12, "maxLength": 700 },
        "bodyStyle": { "$ref": "#/$defs/bodyStyle" },
        "body": {
          "$ref": "#/$defs/textArrayMin4",
          "x-kpmg-minChars": 180
        },
        "chart": { "$ref": "#/$defs/chart" }
      }
    },
    "slideAnalysisWideChartTableText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "body", "chart"],
      "properties": {
        "type": { "const": "analysisWideChartTableText" },
        "title": { "type": "string", "minLength": 12, "maxLength": 50 },
        "strapline": { "type": "string", "minLength": 12, "maxLength": 700 },
        "heading": { "type": "string", "minLength": 6, "maxLength": 120 },
        "bodyStyle": { "$ref": "#/$defs/bodyStyle" },
        "body": {
          "$ref": "#/$defs/textArrayMin4",
          "x-kpmg-minChars": 180
        },
        "chart": { "$ref": "#/$defs/chart" },
        "table": { "$ref": "#/$defs/table" },
        "noteSource": { "type": "string", "minLength": 12, "maxLength": 700 }
      }
    },
    "slideTitleStrapline4TextBoxes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "columns"],
      "properties": {
        "type": { "const": "titleStrapline4TextBoxes" },
        "title": { "type": "string", "minLength": 12, "maxLength": 50 },
        "strapline": { "type": "string", "minLength": 12, "maxLength": 700 },
        "bodyStyle": { "$ref": "#/$defs/bodyStyle" },
        "columns": { "$ref": "#/$defs/columnsMin4" }
      }
    },
    "slideBackCover": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "backCover" },
        "disclaimer": { "type": "string", "minLength": 80, "maxLength": 700 },
        "url": { "type": "string", "minLength": 5, "maxLength": 60 }
      }
    },
    "slide": {
      "oneOf": [
        { "$ref": "#/$defs/slideCover" },
        { "$ref": "#/$defs/slideDivider" },
        { "$ref": "#/$defs/slideDividerDark" },
        { "$ref": "#/$defs/slideDividerLight" },
        { "$ref": "#/$defs/slideContents" },
        { "$ref": "#/$defs/slideOneColumnText" },
        { "$ref": "#/$defs/slideTwoColumnText" },
        { "$ref": "#/$defs/slideAnalysisNarrowTable" },
        { "$ref": "#/$defs/slideAnalysisWideChart2ColsText" },
        { "$ref": "#/$defs/slideAnalysisWideChartTableText" },
        { "$ref": "#/$defs/slideTitleStrapline4TextBoxes" },
        { "$ref": "#/$defs/slideBackCover" }
      ]
    }
  }
}
