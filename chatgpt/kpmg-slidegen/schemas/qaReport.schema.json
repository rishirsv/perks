{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kpmg-slidegen.local/schemas/qaReport.schema.json",
  "title": "Deck QA Report",
  "type": "object",
  "required": [
    "generatedAt",
    "template",
    "valid",
    "errors",
    "warnings",
    "densityFindings",
    "missingSlots",
    "thinSlides",
    "sparseSlides",
    "slotIssues",
    "repairSuggestions",
    "slotMetrics",
    "pagination",
    "overflowRisks",
    "masterApplied",
    "paginationDecisions",
    "overflowEvents",
    "fallbacks",
    "inputSlideCount",
    "outputPptx"
  ],
  "additionalProperties": true,
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "template": { "type": "string" },
    "valid": { "type": "boolean" },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "densityFindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/densityFinding" }
    },
    "densitySummary": {
      "type": "object",
      "properties": {
        "ok": { "type": "number" },
        "thin": { "type": "number" },
        "sparse": { "type": "number" }
      },
      "required": ["ok", "thin", "sparse"],
      "additionalProperties": false
    },
    "missingSlots": {
      "type": "array",
      "items": { "$ref": "#/$defs/slotRef" }
    },
    "thinSlides": {
      "type": "array",
      "items": { "$ref": "#/$defs/densityFinding" }
    },
    "sparseSlides": {
      "type": "array",
      "items": { "$ref": "#/$defs/densityFinding" }
    },
    "slotIssues": {
      "type": "array",
      "items": { "$ref": "#/$defs/slotIssue" }
    },
    "repairSuggestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/repairSuggestion" }
    },
    "slotMetrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/slotMetric" }
    },
    "pagination": {
      "type": "array",
      "items": { "$ref": "#/$defs/paginationEvent" }
    },
    "overflowRisks": {
      "type": "array",
      "items": { "$ref": "#/$defs/overflowRisk" }
    },
    "masterApplied": {
      "type": "array",
      "items": { "$ref": "#/$defs/masterApplied" }
    },
    "paginationDecisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/paginationEvent" }
    },
    "overflowEvents": {
      "type": "array",
      "items": { "$ref": "#/$defs/overflowEvent" }
    },
    "fallbacks": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "overlapSummary": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "strictOverflow": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "inputSlideCount": { "type": "number" },
    "outputPptx": { "type": "string" }
  },
  "$defs": {
    "slotRef": {
      "type": "object",
      "required": ["slideIndex", "slideType", "slot"],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "slot": { "type": "string" }
      }
    },
    "densityFinding": {
      "type": "object",
      "required": [
        "slideIndex",
        "slideType",
        "status",
        "score",
        "minScore",
        "acceptableFloor",
        "shouldRepair"
      ],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "status": {
          "type": "string",
          "enum": [
            "OK",
            "thin but acceptable",
            "too sparse, should be repaired or flagged"
          ]
        },
        "score": { "type": "number" },
        "minScore": { "type": "number" },
        "acceptableFloor": { "type": "number" },
        "shouldRepair": { "type": "boolean" }
      }
    },
    "slotIssue": {
      "type": "object",
      "required": [
        "slideIndex",
        "slideType",
        "slot",
        "kind",
        "code",
        "message",
        "severity",
        "hook",
        "suggestedRemedy"
      ],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "slot": { "type": "string" },
        "kind": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "actual": { "type": ["number", "null"] },
        "target": { "type": ["number", "null"] },
        "hook": { "type": "string" },
        "suggestedRemedy": { "type": "string" }
      }
    },
    "repairSuggestion": {
      "type": "object",
      "required": ["hook", "suggestedRemedy"],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "slot": { "type": ["string", "null"] },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "issueCode": { "type": "string" },
        "hook": { "type": "string" },
        "suggestedRemedy": { "type": "string" }
      }
    },
    "slotMetric": {
      "type": "object",
      "required": ["slideIndex", "slideType", "slot", "kind", "actual", "target", "priority"],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "slot": { "type": "string" },
        "kind": { "type": "string" },
        "actual": { "type": "number" },
        "target": { "type": "number" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "paginationEvent": {
      "type": "object",
      "required": ["slideType", "mode", "originalCount", "splitInto"],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "mode": { "type": "string" },
        "originalCount": { "type": "number" },
        "splitInto": { "type": "number" },
        "rowLimit": { "type": "number" }
      }
    },
    "overflowEvent": {
      "type": "object",
      "required": ["slideType", "event", "mode", "originalCount", "splitInto"],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "event": { "type": "string" },
        "mode": { "type": "string" },
        "originalCount": { "type": "number" },
        "splitInto": { "type": "number" }
      }
    },
    "overflowRisk": {
      "type": "object",
      "required": ["slideType", "mode", "severity", "reason"],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "mode": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "splitInto": { "type": "number" },
        "reason": { "type": "string" },
        "suggestedRemedy": { "type": "string" }
      }
    },
    "masterApplied": {
      "type": "object",
      "required": ["slideIndex", "slideType", "expectedMaster", "appliedMaster", "matched"],
      "additionalProperties": true,
      "properties": {
        "slideIndex": { "type": "number" },
        "slideType": { "type": "string" },
        "expectedMaster": { "type": "string" },
        "appliedMaster": { "type": "string" },
        "matched": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    }
  }
}
