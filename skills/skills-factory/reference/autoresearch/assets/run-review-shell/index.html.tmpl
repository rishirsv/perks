<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Autoresearch Run Review</title>
  <link rel="stylesheet" href="./assets/styles.css" />
</head>
<body>
  <main class="shell">
    <header class="topbar">
      <div class="brand">Autoresearch <span class="mark">run review</span></div>
      <div class="meta" id="run-count">—</div>
    </header>

    <h1>Runs</h1>
    <p style="max-width:640px">A dossier of every recorded benchmark run across the <code>autoresearch</code> and <code>skill-autoresearch</code> skills. Pick a run to read the prompt, the final artifact, the verifier, and the log in one linear pass.</p>

    <div class="filter-bar">
      <div class="filter-group">
        <label>Skill</label>
        <div class="chip-row" id="skill-chips"></div>
      </div>
      <div class="filter-group">
        <label>Status</label>
        <div class="chip-row">
          <button class="chip" data-filter="status" data-value="all" aria-pressed="true">All</button>
          <button class="chip" data-filter="status" data-value="completed" aria-pressed="false">Completed</button>
          <button class="chip" data-filter="status" data-value="partial" aria-pressed="false">Partial</button>
          <button class="chip" data-filter="status" data-value="failed" aria-pressed="false">Failed</button>
        </div>
      </div>
      <div class="filter-group" style="margin-left:auto">
        <label>Sort</label>
        <select class="sort-select" id="sort-select">
          <option value="created-desc">Newest first</option>
          <option value="created-asc">Oldest first</option>
          <option value="failures-desc">Most failures</option>
          <option value="tokens-desc">Most tokens</option>
          <option value="tokens-asc">Fewest tokens</option>
        </select>
      </div>
    </div>

    <div id="run-list" class="run-list"></div>

    <p class="muted" style="margin-top:40px;font-family:var(--mono);font-size:12px">
      Generated {{GENERATED_AT}} · {{RUN_COUNT}} run(s) across {{SKILL_COUNT}} skill(s).
    </p>
  </main>

  <script src="./assets/ui.js"></script>
  <script src="./data/index.js"></script>
  <script src="./assets/index.js"></script>
</body>
</html>
