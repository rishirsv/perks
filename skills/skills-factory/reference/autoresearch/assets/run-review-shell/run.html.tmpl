<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{RUN_TITLE}} — Autoresearch Run Review</title>
  <link rel="stylesheet" href="../../assets/styles.css" />
</head>
<body>
  <main class="shell">
    <header class="topbar">
      <div class="brand">Autoresearch <span class="mark">run review</span></div>
      <div class="meta">{{RUN_ID}}</div>
    </header>

    <nav class="crumbs"><a href="../../index.html">← All runs</a></nav>

    <section class="run-header">
      <div class="run-id" id="run-id">—</div>
      <h1 id="run-title" class="run-title">—</h1>
      <div class="run-sub">
        <span>Skill <span id="run-skill"></span></span>
        <span>Created <span id="run-created"></span></span>
        <span>Model <span id="run-model"></span></span>
        <span>Scenarios <span id="run-scenarios"></span></span>
        <span>Overall <span id="run-status"></span></span>
      </div>
      <div class="run-links" id="run-links"></div>
    </section>

    <section class="outcome">
      <div class="lede" id="outcome-lede"></div>
      <div class="stat">
        <div class="label">Pass / Fail</div>
        <div id="stat-passfail"></div>
      </div>
      <div class="stat">
        <div class="label">Avg tokens</div>
        <div id="stat-tokens"></div>
      </div>
      <div class="stat">
        <div class="label">Generated</div>
        <div id="stat-files"></div>
      </div>
      <div class="stat">
        <div class="label">Verifier</div>
        <div id="stat-verifier"></div>
      </div>
    </section>

    <section class="section">
      <div class="section-header"><h2>Scenarios</h2></div>
      <div id="scenario-strip" class="scenario-strip" role="tablist" tabindex="0"></div>
    </section>

    <section class="section">
      <div class="section-header"><h2>Scenario story</h2></div>
      <div id="scenario-body"></div>
    </section>

    <section class="section" id="adapter-panels-wrap">
      <div id="adapter-panels"></div>
    </section>

    <section class="section">
      <div class="section-header"><h2>Artifacts</h2></div>
      <div id="artifacts"></div>
    </section>

    <section class="section">
      <div class="section-header"><h2>Changed files</h2></div>
      <div id="files"></div>
    </section>

    <section class="section">
      <div class="section-header"><h2>Event timeline</h2></div>
      <div class="log-filter">
        <span style="text-transform:uppercase;letter-spacing:.12em">Show</span>
        <button class="chip" data-log-filter="agent" aria-pressed="true">Agent</button>
        <button class="chip" data-log-filter="cmd" aria-pressed="true">Command</button>
        <button class="chip" data-log-filter="file" aria-pressed="true">File</button>
        <button class="chip" data-log-filter="turn" aria-pressed="true">Turn</button>
        <button class="chip" data-log-filter="error" aria-pressed="true">Error</button>
        <input type="search" class="log-search" id="log-search" placeholder="Filter events…" />
      </div>
      <div id="timeline"></div>
      <div style="margin-top:14px;font-family:var(--mono);font-size:12px" class="muted">
        Raw logs: <span id="raw-log-links"></span>
      </div>
    </section>

    <p class="muted" style="margin-top:60px;font-family:var(--mono);font-size:12px">
      Generated {{GENERATED_AT}} from repo artifacts. All artifact previews are local copies; the original workspace may be gone.
    </p>
  </main>

  <script src="../../assets/ui.js"></script>
  <script src="../../data/runs/{{RUN_KEY}}.js"></script>
  <script src="../../assets/app.js"></script>
</body>
</html>
