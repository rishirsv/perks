{
  "_description": "Engagement Letter Placeholder Schema — drives the GPT interview flow and Canvas display. Each variable maps to a {{PLACEHOLDER}} in the .docx templates.",
  "schema_version": "1.0",
  "templates": {
    "buyside": "buyside-engagement-letter.docx",
    "sellside": "sellside-engagement-letter.docx"
  },
  "interview_groups": [
    {
      "group": 1,
      "label": "Deal Basics",
      "description": "Core deal identifiers and template selection.",
      "variables": [
        {
          "key": "TEMPLATE_TYPE",
          "type": "choice",
          "label": "Template type",
          "options": ["buyside", "sellside"],
          "example": "buyside",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Determines which .docx template is loaded and which variables are relevant."
        },
        {
          "key": "PROJECT_CODE_NAME",
          "type": "field",
          "label": "Project name",
          "example": "Atlas",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "User-facing intake should ask for project name. Internally this maps to PROJECT_CODE_NAME placeholders."
        },
        {
          "key": "CHOICE_DEAL_TYPE",
          "type": "choice",
          "label": "Deal type",
          "options": ["investment in", "acquisition of"],
          "example": "acquisition of",
          "required": false,
          "applies_to": ["buyside"]
        },
        {
          "key": "DEAL_DESCRIPTION",
          "type": "field",
          "label": "Deal description (sellside)",
          "example": "potential divestment of Target",
          "required": false,
          "applies_to": ["sellside"],
          "notes": "Default to 'potential divestment of Target'. Do not ask unless user explicitly wants different wording."
        },
        {
          "key": "INDUSTRY",
          "type": "choice",
          "label": "Industry",
          "options": [
            "construction", "eyecare", "healthcare", "hvac",
            "manufacturing", "prof_services", "real_estate",
            "service", "supermarket", "tech", "transportation",
            "retail", "banking", "insurance", "telecomm", "aerospace", "building",
            "generic"
          ],
          "example": "healthcare",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Controls which FDD scope section is inserted from scope-library.json. Use 'generic' to insert only the common scope skeleton."
        }
      ]
    },
    {
      "group": 2,
      "label": "Client Information",
      "description": "Client legal details and addressing.",
      "variables": [
        {
          "key": "CLIENT_LEGAL_NAME",
          "type": "field",
          "label": "Client legal entity name",
          "example": "Acme Holdings Inc.",
          "required": true,
          "applies_to": ["buyside", "sellside"],
          "notes": "Used in multiple positions (header, body intro, Appendix B, acceptance block)."
        },
        {
          "key": "CLIENT_LEGAL_NAME_FULL",
          "type": "field",
          "label": "Client full legal name (body intro)",
          "example": "Acme Holdings Inc.",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_LEGAL_NAME_ACCEPTANCE",
          "type": "field",
          "label": "Client legal name (acceptance block)",
          "example": "Acme Holdings Inc.",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Usually same as CLIENT_LEGAL_NAME."
        },
        {
          "key": "CLIENT_NAME_SHORT",
          "type": "field",
          "label": "Client short name (header)",
          "example": "Acme Holdings",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_ADDRESS_LINE_1",
          "type": "field",
          "label": "Client address line 1",
          "example": "123 Bay Street, Suite 4000",
          "required": true,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_ADDRESS_LINE_2",
          "type": "field",
          "label": "Client address line 2",
          "example": "Toronto, Ontario M5J 2T3",
          "required": true,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_COUNTRY",
          "type": "field",
          "label": "Client country",
          "example": "Canada",
          "required": true,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_COUNTRY_2",
          "type": "field",
          "label": "Client country (Appendix B)",
          "example": "Canada",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_ADDRESS_LINE_3",
          "type": "field",
          "label": "Client address line 3",
          "example": "",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_CONTACT_NAME",
          "type": "field",
          "label": "Client contact name",
          "example": "John Smith",
          "required": true,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_CONTACT_NAME_TITLE",
          "type": "field",
          "label": "Client contact name and title",
          "example": "John Smith, Managing Director",
          "required": true,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "EL_SIGNATORY_NAME",
          "type": "field",
          "label": "EL signatory name",
          "example": "John Smith",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        }
      ]
    },
    {
      "group": 3,
      "label": "Target Information",
      "description": "Details about the target company or business being acquired/divested.",
      "variables": [
        {
          "key": "TARGET_DESCRIPTION",
          "type": "field",
          "label": "Target description",
          "example": "HealthCo Medical Clinics Inc.",
          "required": true,
          "applies_to": ["buyside", "sellside"],
          "notes": "Buyside: 'Target company name OR the widget division of...'. Sellside: 'your business / the AAA division of Client'."
        },
        {
          "key": "TARGET_DEFINED_TERM",
          "type": "field",
          "label": "Target defined term",
          "example": "(\"Target\")",
          "required": false,
          "applies_to": ["sellside"],
          "notes": "Defaults to '(\"Target\")'. Do not ask unless user explicitly requests a different defined term."
        },
        {
          "key": "TARGET_DESCRIPTION_DETAIL",
          "type": "field",
          "label": "Target description detail (Appendix B)",
          "example": "the cardiac services division of HealthCo",
          "required": false,
          "applies_to": ["buyside"]
        },
        {
          "key": "TARGET_LEGAL_NAME_FULL",
          "type": "field",
          "label": "Target legal name",
          "example": "HealthCo Medical Clinics Inc.",
          "required": true,
          "applies_to": ["buyside"]
        }
      ]
    },
    {
      "group": 4,
      "label": "Dates & Timing",
      "description": "Key dates for the engagement letter and project timeline.",
      "variables": [
        {
          "key": "LETTER_DATE",
          "type": "field",
          "label": "Letter date",
          "example": "January 15, 2026",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "DATE_COMMENCE",
          "type": "field",
          "label": "Engagement commencement date",
          "example": "January 20, 2026",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "DATE_DRAFT_DELIVERY",
          "type": "field",
          "label": "Draft report delivery date",
          "example": "February 15, 2026",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "FAL_DATE",
          "type": "field",
          "label": "Factual accuracy letter date",
          "example": "February 1, 2026",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "FAL_LETTER_DATE",
          "type": "field",
          "label": "FAL letter date (sellside)",
          "example": "February 1, 2026",
          "required": false,
          "applies_to": ["sellside"]
        }
      ]
    },
    {
      "group": 5,
      "label": "Team",
      "description": "KPMG team members and client-side management contact.",
      "variables": [
        {
          "key": "TEAM_PARTNER_NAME",
          "type": "field",
          "label": "Lead engagement partner",
          "example": "Jane Doe",
          "required": true,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "TEAM_TAX_PARTNER_NAME",
          "type": "field",
          "label": "M&A tax partner",
          "example": "Robert Chen",
          "required": false,
          "applies_to": ["buyside"],
          "notes": "Only used in buyside template."
        },
        {
          "key": "TEAM_SENIOR_MANAGER_NAME",
          "type": "field",
          "label": "Engagement senior manager",
          "example": "Michael Williams",
          "required": true,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "SIGNING_PARTNER_NAME",
          "type": "field",
          "label": "Signing partner name",
          "example": "Jane Doe",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Appears in the signature block. May be the same as TEAM_PARTNER_NAME."
        },
        {
          "key": "PROJECT_NAME_HEADER",
          "type": "field",
          "label": "Project name (header)",
          "example": "Project Atlas",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        }
      ]
    },
    {
      "group": 6,
      "label": "Fees & Invoicing",
      "description": "Professional fee estimates and invoicing details.",
      "variables": [
        {
          "key": "FEE_DISCOUNT_CLAUSE",
          "type": "field",
          "label": "Fee discount clause",
          "example": "We are pleased to offer a 10%",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Appears before the fee table. Include full clause text."
        },
        {
          "key": "FEE_NET_CLAUSE",
          "type": "field",
          "label": "Fee net clause",
          "example": "(estimates are net of your 10%",
          "required": false,
          "applies_to": ["buyside"]
        },
        {
          "key": "FEE_FDD_LOW",
          "type": "field",
          "label": "FDD fee estimate (low, full dollars)",
          "example": "150000",
          "required": true,
          "applies_to": ["buyside"],
          "notes": "Number only. Enter full dollars (e.g., 150000)."
        },
        {
          "key": "FEE_FDD_HIGH",
          "type": "field",
          "label": "FDD fee estimate (high, full dollars)",
          "example": "200000",
          "required": true,
          "applies_to": ["buyside"],
          "notes": "Number only. Enter full dollars (e.g., 200000)."
        },
        {
          "key": "FEE_TAX_LOW",
          "type": "field",
          "label": "Tax DD fee estimate (low, full dollars)",
          "example": "30000",
          "required": false,
          "applies_to": ["buyside"],
          "notes": "Number only. Enter full dollars (e.g., 30000) or leave blank if not applicable."
        },
        {
          "key": "FEE_TAX_HIGH",
          "type": "field",
          "label": "Tax DD fee estimate (high, full dollars)",
          "example": "50000",
          "required": false,
          "applies_to": ["buyside"],
          "notes": "Number only. Enter full dollars (e.g., 50000) or leave blank if not applicable."
        },
        {
          "key": "FEE_FDD_RANGE",
          "type": "field",
          "label": "FDD fee range (sellside)",
          "example": "$150,000 to $200,000",
          "required": true,
          "applies_to": ["sellside"],
          "notes": "Full formatted range including dollar signs."
        },
        {
          "key": "FEE_UPDATE_AMOUNT",
          "type": "field",
          "label": "Report update fee (sellside)",
          "example": "$15,000 per update",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "FEE_DISCOUNT_PERCENT",
          "type": "field",
          "label": "Fee discount percent (sellside)",
          "example": "10%",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "FEE_INVOICE_AMOUNT",
          "type": "field",
          "label": "Invoice installment amount (sellside)",
          "example": "$75,000 + 10% technology and support charge + applicable sales taxes",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "BILLING_ENTITY_NAME",
          "type": "field",
          "label": "Billing entity legal name",
          "example": "Acme Holdings Inc.",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Derived by default from CLIENT_LEGAL_NAME unless user explicitly overrides."
        }
      ]
    },
    {
      "group": 7,
      "label": "Relationship Disclosures",
      "description": "Audit independence, existing relationships, and confidentiality.",
      "variables": [
        {
          "key": "CHOICE_INDEPENDENCE_APPLIES",
          "type": "choice",
          "label": "Independence considerations apply?",
          "options": ["yes", "no"],
          "example": "no",
          "required": true,
          "applies_to": ["buyside", "sellside"],
          "notes": "If yes, the Independence Considerations section remains and CHOICE_SEC_STATUS is required. If no, the entire Independence Considerations section is removed during generation."
        },
        {
          "key": "CHOICE_SEC_STATUS",
          "type": "choice",
          "label": "SEC / audit client status",
          "options": [
            "a SEC audit client",
            "an affiliate of a SEC audit client",
            "a Canadian Reporting Issuer audit client",
            "a related entity of a Reporting Issuer audit client"
          ],
          "example": "a SEC audit client",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Required only if Independence Considerations apply (CHOICE_INDEPENDENCE_APPLIES=yes). Select the exact option that applies."
        },
        {
          "key": "CHOICE_REPORT_FORMAT",
          "type": "choice",
          "label": "Report format",
          "options": [
            "a PDF written report and an Excel data book",
            "a PDF written report",
            "an Excel data book"
          ],
          "example": "a PDF written report and an Excel data book",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CHOICE_REPORT_BRANDING",
          "type": "field",
          "label": "Report branding",
          "example": "KPMG-branded",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "EXISTING_SERVICES_DESCRIPTION",
          "type": "field",
          "label": "Existing KPMG services to Target/Bidder",
          "example": "KPMG provides audit, tax, and advisory services",
          "required": false,
          "applies_to": ["buyside", "sellside"],
          "notes": "Only if there is a conflict/relationship to disclose."
        },
        {
          "key": "EXISTING_SERVICES_CAVEAT",
          "type": "field",
          "label": "Existing services caveat",
          "example": "although as of the date of this letter, KPMG has not been engaged by Target with respect to the Transaction",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "BIDDER_NAME",
          "type": "field",
          "label": "Identified bidder name (sellside)",
          "example": "BuyerCo Partners LLC",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "CLIENT_AND_TARGET",
          "type": "field",
          "label": "Client and Target (disclosure sections)",
          "example": "Client and Target",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLIENT_AND_BIDDER",
          "type": "field",
          "label": "Client and Bidder (sellside disclosure)",
          "example": "Client and Bidder",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "CLIENT_AND_OR_TARGET",
          "type": "field",
          "label": "Client and/or Target",
          "example": "Client and/or Target",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "CLIENT_OR_TARGET",
          "type": "field",
          "label": "Client or Target",
          "example": "Client or Target",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "CHOICE_CLIENT_OR_TARGET",
          "type": "choice",
          "label": "Client or Target (repeated choice)",
          "options": ["Client", "Target"],
          "example": "Target",
          "required": false,
          "applies_to": ["sellside"],
          "notes": "Defaults to 'Target' for sellside unless user explicitly overrides."
        },
        {
          "key": "CHOICE_CLIENT_OR_TARGET_POSSESSIVE",
          "type": "choice",
          "label": "Client's or Target's (possessive)",
          "options": ["Client's", "Target's"],
          "example": "Target's",
          "required": false,
          "applies_to": ["sellside"],
          "notes": "Defaults to \"Target's\" for sellside unless user explicitly overrides."
        },
        {
          "key": "CHOICE_CLIENT_OR_TARGET_POSSESSIVE_2",
          "type": "choice",
          "label": "Client's or Target's (MDR section)",
          "options": ["Client's", "Target's"],
          "example": "Target's",
          "required": false,
          "applies_to": ["sellside"],
          "notes": "Defaults to \"Target's\" for sellside unless user explicitly overrides."
        },
        {
          "key": "CONFIDENTIALITY_PROCEDURES",
          "type": "field",
          "label": "Confidentiality procedures text",
          "example": "Information barriers have been established between the KPMG team providing services to Client and the KPMG team providing services to Target...",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "INDEMNITY_EXCLUSION",
          "type": "field",
          "label": "Indemnity exclusion party",
          "example": "(other than Target)",
          "required": false,
          "applies_to": ["buyside", "sellside"]
        },
        {
          "key": "CLOSING_SENTIMENT",
          "type": "field",
          "label": "Closing sentiment",
          "example": "interesting and challenging",
          "required": false,
          "applies_to": ["buyside"]
        },
        {
          "key": "FAL_ADDRESS",
          "type": "field",
          "label": "FAL address (sellside)",
          "example": "123 Bay Street, Suite 4000, Toronto, ON",
          "required": false,
          "applies_to": ["sellside"]
        },
        {
          "key": "FAL_OTHER_REPRESENTATIONS",
          "type": "field",
          "label": "FAL other representations (sellside)",
          "example": "All material contracts have been disclosed to KPMG;",
          "required": false,
          "applies_to": ["sellside"]
        }
      ]
    }
  ],
  "guidance_blocks": {
    "_description": "GUIDANCE placeholders in double-curly braces (e.g., {{GUIDANCE_01}}) are deleted (entire paragraph removed) during generation. Bracketed guidance text (e.g., [GUIDANCE: ...]) remains in the output document for the user to review/edit.",
    "placeholders": [
      "GUIDANCE_01", "GUIDANCE_02", "GUIDANCE_03", "GUIDANCE_04", "GUIDANCE_05",
      "GUIDANCE_06", "GUIDANCE_07", "GUIDANCE_08", "GUIDANCE_09", "GUIDANCE_10",
      "GUIDANCE_11", "GUIDANCE_12", "GUIDANCE_13", "GUIDANCE_14", "GUIDANCE_15",
      "GUIDANCE_16", "GUIDANCE_17", "GUIDANCE_18"
    ]
  }
}
