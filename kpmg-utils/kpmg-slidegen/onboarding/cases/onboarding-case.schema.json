{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kpmg-slidegen/onboarding/cases/onboarding-case.schema.json",
  "title": "KPMG SlideGen Onboarding Case",
  "description": "Repo-only contract for a single layout onboarding case workspace.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "caseId",
    "templateName",
    "layoutId",
    "source",
    "artifacts"
  ],
  "properties": {
    "caseId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "templateName": {
      "type": "string",
      "const": "kpmg-diligence"
    },
    "layoutId": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pptxPath",
        "slideNumber"
      ],
      "properties": {
        "pptxPath": {
          "type": "string",
          "minLength": 1
        },
        "slideNumber": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "primitiveRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z][A-Za-z0-9-]*@[1-9][0-9]*$"
    },
    "builderMode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "existing-primitive",
        "new-primitive"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "extracted",
        "classified",
        "scaffolded",
        "rendered",
        "compared",
        "approved",
        "promoted"
      ],
      "default": "extracted"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intake",
        "extractRaw",
        "extractNormalized",
        "fingerprint",
        "classify",
        "candidateLayout",
        "candidateDeckSpec",
        "review"
      ],
      "properties": {
        "intake": {
          "type": "string",
          "const": "intake.json"
        },
        "extractRaw": {
          "type": "string",
          "const": "extract.raw.json"
        },
        "extractNormalized": {
          "type": "string",
          "const": "extract.normalized.json"
        },
        "fingerprint": {
          "type": "string",
          "const": "fingerprint.json"
        },
        "classify": {
          "type": "string",
          "const": "classify.json"
        },
        "candidateLayout": {
          "type": "string",
          "const": "candidate.layout.json"
        },
        "candidateDeckSpec": {
          "type": "string",
          "const": "candidate.deckSpec.json"
        },
        "candidatePrimitive": {
          "type": "string",
          "const": "candidate.primitive.json"
        },
        "candidateBuilder": {
          "type": "string",
          "const": "candidate.builder.js"
        },
        "review": {
          "type": "string",
          "const": "review.md"
        }
      }
    }
  }
}
