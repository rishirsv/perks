{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kpmg-slidegen/onboarding/cases/classification.schema.json",
  "title": "KPMG SlideGen Onboarding Classification",
  "description": "Repo-only contract for a fail-closed primitive classification artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "caseId",
    "acceptanceThreshold",
    "topScore",
    "recommendedPrimitiveRef",
    "requiresManualSelection",
    "manualSelectionReason",
    "rankedAlternatives"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "caseId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "acceptanceThreshold": {
      "type": "number",
      "minimum": 0
    },
    "topScore": {
      "type": "number"
    },
    "recommendedPrimitiveRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z][A-Za-z0-9-]*@[1-9][0-9]*$"
    },
    "requiresManualSelection": {
      "type": "boolean"
    },
    "manualSelectionReason": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "zero-score",
        "below-threshold",
        "ambiguous-tie"
      ]
    },
    "rankedAlternatives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rankedAlternative"
      }
    }
  },
  "$defs": {
    "rankedAlternative": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primitiveRef",
        "primitiveId",
        "score",
        "reasons"
      ],
      "properties": {
        "primitiveRef": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9-]*@[1-9][0-9]*$"
        },
        "primitiveId": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9-]*$"
        },
        "score": {
          "type": "number"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
