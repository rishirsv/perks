{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kpmg-slidegen/templates-src/kpmg-diligence/primitives/primitive.schema.json",
  "title": "KPMG SlideGen Primitive",
  "description": "Repo-only authoring contract for a reusable slide primitive. Phase 1 introduces the schema only; runtime wiring comes later.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "builderModule",
    "geometryKinds",
    "requiredGeometry",
    "paginationPolicyKey",
    "master",
    "slotSchemaRef"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9-]*$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "builderModule": {
      "type": "string",
      "pattern": "^generator/builders/primitives/.+\\.(mjs|js)$"
    },
    "geometryKinds": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/geometryKind"
      }
    },
    "requiredGeometry": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "optionalGeometry": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "paginationPolicyKey": {
      "type": "string",
      "minLength": 1
    },
    "master": {
      "type": "string",
      "minLength": 1
    },
    "slotSchemaRef": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "scaffoldFixture": {
      "$ref": "#/$defs/scaffoldFixture"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "geometryKind": {
      "type": "string",
      "enum": [
        "box",
        "boxList",
        "boxTree",
        "point",
        "line",
        "imageBox",
        "tableGrid"
      ]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registryBehavior": {
          "type": "string",
          "enum": [
            "manual",
            "generated"
          ]
        },
        "compareThresholds": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "scaffoldFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deckSpecPath"
      ],
      "properties": {
        "deckSpecPath": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
