{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kpmg-slidegen/templates-src/kpmg-diligence/layouts/layout-instance.schema.json",
  "title": "KPMG SlideGen Layout Instance",
  "description": "Repo-only authoring contract for a user-facing layout instance backed by a primitive definition and the runtime geometry contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "primitive",
    "description",
    "templateLayout",
    "geometry"
  ],
  "properties": {
    "type": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*$"
    },
    "primitive": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9-]*@[1-9][0-9]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "templateLayout": {
      "type": "string",
      "minLength": 1
    },
    "geometry": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/geometryValue"
      }
    },
    "slots": {
      "type": "object",
      "default": {}
    },
    "densityTarget": {
      "type": [
        "object",
        "null"
      ]
    },
    "slotOverrides": {
      "type": "object",
      "default": {}
    },
    "comparePolicyOverrides": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "masterOverride": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "geometryValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/box"
        },
        {
          "$ref": "#/$defs/boxArray"
        },
        {
          "$ref": "#/$defs/boxTree"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/semanticObject"
        }
      ]
    },
    "boxArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/box"
      }
    },
    "boxTree": {
      "anyOf": [
        {
          "$ref": "#/$defs/box"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boxTree"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/boxTree"
          }
        }
      ]
    },
    "semanticObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/semanticValue"
      }
    },
    "semanticArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/semanticValue"
      }
    },
    "semanticValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/box"
        },
        {
          "$ref": "#/$defs/semanticObject"
        },
        {
          "$ref": "#/$defs/semanticArray"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "box": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "w",
        "h"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "h": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
