{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kpmg-slidegen/docs/onboarding/compare-scorecard.schema.json",
  "title": "KPMG SlideGen Compare Scorecard",
  "description": "Schema for compare scorecards produced by onboarding image comparison and any explicit manual promotion review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deterministicStatus",
    "manualDisposition",
    "approvedExceptions",
    "pass",
    "metrics",
    "thresholds",
    "checks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "deterministicStatus": {
      "description": "Raw deterministic compare outcome before any manual review override.",
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "manualDisposition": {
      "description": "Optional human review disposition that can approve deterministic failures with recorded exceptions or block promotion explicitly.",
      "type": "string",
      "enum": [
        "unreviewed",
        "accepted",
        "rejected",
        "needs-follow-up"
      ]
    },
    "approvedExceptions": {
      "description": "Recorded reasons for accepting a deterministic compare failure. Required when manualDisposition accepts a deterministic failure.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pass": {
      "description": "Final promotion readiness after applying deterministicStatus and any manual review disposition.",
      "type": "boolean"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimensions",
        "pixelDelta",
        "similarity"
      ],
      "properties": {
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "width",
            "height"
          ],
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "pixelDelta": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "changedPixels",
            "totalPixels",
            "changedPixelRatio",
            "meanAbs",
            "rms",
            "maxAbs",
            "changedBounds"
          ],
          "properties": {
            "changedPixels": {
              "type": "integer",
              "minimum": 0
            },
            "totalPixels": {
              "type": "integer",
              "minimum": 0
            },
            "changedPixelRatio": {
              "type": "number",
              "minimum": 0
            },
            "meanAbs": {
              "type": "number",
              "minimum": 0
            },
            "rms": {
              "type": "number",
              "minimum": 0
            },
            "maxAbs": {
              "type": "integer",
              "minimum": 0
            },
            "changedBounds": {
              "anyOf": [
                {
                  "type": "null"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "left",
                    "top",
                    "right",
                    "bottom"
                  ],
                  "properties": {
                    "left": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "top": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "right": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "bottom": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                }
              ]
            }
          }
        },
        "similarity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ssim",
            "phash"
          ],
          "properties": {
            "ssim": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            },
            "phash": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reference",
                "candidate",
                "distance"
              ],
              "properties": {
                "reference": {
                  "type": "string"
                },
                "candidate": {
                  "type": "string"
                },
                "distance": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      },
      "required": [
        "changedPixelRatioMax",
        "meanAbsMax",
        "rmsMax"
      ],
      "properties": {
        "changedPixelRatioMax": {
          "type": "number",
          "minimum": 0
        },
        "meanAbsMax": {
          "type": "number",
          "minimum": 0
        },
        "rmsMax": {
          "type": "number",
          "minimum": 0
        },
        "ssimMin": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/checkResult"
      },
      "required": [
        "changedPixelRatio",
        "meanAbs",
        "rms"
      ],
      "properties": {
        "changedPixelRatio": {
          "$ref": "#/$defs/checkResult"
        },
        "meanAbs": {
          "$ref": "#/$defs/checkResult"
        },
        "rms": {
          "$ref": "#/$defs/checkResult"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "deterministicStatus": {
            "const": "pass"
          },
          "manualDisposition": {
            "enum": [
              "unreviewed",
              "accepted"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "pass": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deterministicStatus": {
            "const": "pass"
          },
          "manualDisposition": {
            "enum": [
              "rejected",
              "needs-follow-up"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "pass": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deterministicStatus": {
            "const": "fail"
          },
          "manualDisposition": {
            "const": "accepted"
          }
        }
      },
      "then": {
        "properties": {
          "pass": {
            "const": true
          },
          "approvedExceptions": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deterministicStatus": {
            "const": "fail"
          },
          "manualDisposition": {
            "enum": [
              "unreviewed",
              "rejected",
              "needs-follow-up"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "pass": {
            "const": false
          }
        }
      }
    }
  ],
  "$defs": {
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actual",
        "pass"
      ],
      "properties": {
        "actual": {
          "type": "number"
        },
        "max": {
          "type": "number",
          "minimum": 0
        },
        "min": {
          "type": "number"
        },
        "pass": {
          "type": "boolean"
        }
      }
    }
  }
}
