{
  "name": "kpmg-slidegen",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Template-driven PPTX generator with QA and optional visual postprocess checks.",
  "scripts": {
    "generate": "node generator/index.js --in presets/authoring/detailed.deckSpec.json",
    "generate:concise": "node generator/index.js --in presets/authoring/concise.deckSpec.json",
    "generate:detailed": "node generator/index.js --in presets/authoring/detailed.deckSpec.json",
    "generate:extensive": "node generator/index.js --in presets/authoring/extensive.deckSpec.json",
    "qa": "npm run -s test:pr",
    "schema:validate:authoring": "node scripts/validate-authoring-fragments.mjs",
    "test:contracts": "node scripts/test-contracts.mjs",
    "test:authoring-schema-validation": "node scripts/test-authoring-schema-validation.mjs",
    "test:codegen-onboarded-registry": "node scripts/test-codegen-onboarded-registry.mjs",
    "test:codegen-source-reproducibility": "node scripts/test-codegen-source-reproducibility.mjs",
    "test:codegen-full-repo-contracts": "node scripts/test-codegen-full-repo-contracts.mjs",
    "test:changed-layout-detection": "node scripts/test-changed-layouts-selection.mjs",
    "test:skill-bundle-determinism": "node scripts/test-skill-bundle-determinism.mjs",
    "test:onboarding-classification": "node scripts/test-onboarding-classification.mjs",
    "test:onboarding-compare-dimensions": "node scripts/test-onboarding-compare-dimensions.mjs",
    "test:fixtures": "node scripts/test-fixtures.mjs",
    "test:structure": "node scripts/test-structure.mjs",
    "test:render": "node scripts/test-render.mjs",
    "test:visual": "node scripts/test-visual.mjs",
    "test:onboarding": "node scripts/test-onboarding.mjs",
    "test:changed-layouts": "node scripts/test-changed-layouts.mjs",
    "test:primitive-stress": "node scripts/test-primitive-stress.mjs",
    "test:pr": "node scripts/test-pr.mjs",
    "test:nightly": "node scripts/test-nightly.mjs",
    "test:dist": "node scripts/test-dist.mjs",
    "docs:verify": "node scripts/docs-verify.mjs",
    "skill:sync": "node scripts/sync-skill-bundle.mjs",
    "skill:verify": "node scripts/verify-skill-bundle.mjs",
    "skill:smoke": "node scripts/verify-skill-bundle.mjs",
    "smoke": "npm run -s test:render",
    "dev:cover": "node scripts/dev/render-cover-sample.mjs",
    "dev:analysis-narrow": "node scripts/dev/render-analysis-narrow-sample.mjs",
    "onboard:extract": "node scripts/onboarding/extract-case.mjs",
    "onboard:classify": "node scripts/onboarding/classify-case.mjs",
    "onboard:scaffold": "node scripts/onboarding/scaffold-case.mjs",
    "onboard:render": "node scripts/onboarding/render-candidate.mjs",
    "onboard:compare": "node scripts/onboarding/compare-candidate.mjs",
    "onboard:promote": "node scripts/onboarding/promote-layout.mjs",
    "onboard:run": "node scripts/onboarding/run-layout-onboarding.mjs",
    "onboard:regen": "node scripts/codegen/generate-runtime-aggregates.mjs",
    "onboard:test-changed": "node scripts/onboarding/test-changed.mjs",
    "onboard:verify-generated": "node scripts/codegen/generate-runtime-aggregates.mjs --check",
    "codegen:bootstrap-authoring": "node scripts/codegen/bootstrap-authoring-from-runtime.mjs",
    "codegen:runtime-package": "node scripts/codegen/generate-runtime-aggregates.mjs",
    "codegen:onboarded-registry": "node scripts/codegen/generate-runtime-aggregates.mjs"
  },
  "dependencies": {
    "image-size": "^2.0.2",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "acorn": "^8.15.0",
    "ajv": "^8.18.0"
  }
}
